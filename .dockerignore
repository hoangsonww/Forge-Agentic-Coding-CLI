# Keep build context small and reproducible.
# Anything the Dockerfile doesn't explicitly COPY should be excluded.

.git
.github
.vscode
.idea
node_modules
dist
coverage
.nyc_output

# Local state / caches
.forge
.cache
tmp
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment & secrets (never ship into images)
.env
.env.*
*.pem
*.key
*.crt

# Test + dev artefacts not needed at runtime
test
*.test.ts
*.spec.ts
examples
docs
docker
Dockerfile*
.dockerignore

# OS cruft
.DS_Store
Thumbs.db
