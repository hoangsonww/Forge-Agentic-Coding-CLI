node_modules/
dist/
coverage/
*.log
.env
.env.local
.DS_Store

# .vscode — commit shared editor config, ignore per-user noise.
#   settings.json    — workspace formatter, tsdk, ESLint wiring
#   extensions.json  — recommended extensions for contributors
#   launch.json      — debug configs for bin/forge.js, tests, UI
#   tasks.json       — build/test/lint task runners
# Anything else under .vscode/ (caches, per-user overrides, sftp creds,
# local histories) stays out of the repo.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

.idea/workspace.xml
*.tsbuildinfo
.forge/
forge-debug-*.log
tmp/

# Agentic coding tooling
#   Commit shared config (.claude/, .codex/, .cursor/, .agents/) so every
#   contributor's coding agent sees the same rules, skills, and
#   permissions. Ignore only per-user overrides and transient state.
.claude/settings.local.json
.claude/.local/
.codex/settings.local.toml
.codex/.local/
.cursor/.local/
