{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: build",
      "type": "npm",
      "script": "build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$tsc"],
      "presentation": { "reveal": "silent", "panel": "shared", "clear": true }
    },
    {
      "label": "npm: build:watch",
      "type": "npm",
      "script": "build:watch",
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"],
      "presentation": { "reveal": "silent", "panel": "dedicated" }
    },
    {
      "label": "npm: test",
      "type": "npm",
      "script": "test",
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared", "clear": true }
    },
    {
      "label": "npm: test:coverage",
      "type": "npm",
      "script": "test:coverage",
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true }
    },
    {
      "label": "npm: typecheck",
      "type": "npm",
      "script": "typecheck",
      "problemMatcher": ["$tsc"],
      "presentation": { "reveal": "silent", "panel": "shared" }
    },
    {
      "label": "npm: lint",
      "type": "npm",
      "script": "lint",
      "problemMatcher": ["$eslint-stylish"],
      "presentation": { "reveal": "silent", "panel": "shared" }
    },
    {
      "label": "npm: format",
      "type": "npm",
      "script": "format",
      "presentation": { "reveal": "silent", "panel": "shared" }
    },
    {
      "label": "forge: pre-merge (format + lint + build + test)",
      "dependsOrder": "sequence",
      "dependsOn": ["npm: format", "npm: lint", "npm: build", "npm: test"],
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "detail": "Runs the full CI-matching pipeline locally before pushing."
    },
    {
      "label": "forge: regenerate metrics",
      "type": "shell",
      "command": "bash",
      "args": ["scripts/metrics.sh"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "docker: build image",
      "type": "shell",
      "command": "docker",
      "args": ["build", "-f", "docker/Dockerfile", "-t", "forge/core:dev", "."],
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
